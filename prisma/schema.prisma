// Prisma schema — grows one phase at a time.
// Phase 0: auth models (User/Account/Session/VerificationToken) for Auth.js + Google login.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  MEMBER
}

enum ProjectRole {
  OWNER
  EDITOR
  VIEWER
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ActivityType {
  CREATED
  UPDATED
  STATUS_CHANGED
  COMMENTED
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          UserRole  @default(MEMBER)
  accounts      Account[]
  sessions      Session[]
  createdProjects Project[] @relation("ProjectCreatedBy")
  memberships   ProjectMember[]
  ownedTasks    Task[]    @relation("TaskOwner")
  assignedTasks Task[]    @relation("TaskAssignee")
  comments      Comment[]
  activities    TaskActivity[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

// Phase 1: the catalog projects hang off of.

model Client {
  id        String   @id @default(cuid())
  name      String   @unique
  notes     String?
  projects  Project[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id          String           @id @default(cuid())
  name        String           @unique
  description String?
  color       String           @default("#0073ea")
  projects    ProjectProduct[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

// Phase 2: projects belong to a client and use many products.

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  clientId    String
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  client    Client           @relation(fields: [clientId], references: [id], onDelete: Restrict)
  createdBy User             @relation("ProjectCreatedBy", fields: [createdById], references: [id])
  products  ProjectProduct[]
  members   ProjectMember[]
  statuses  WorkflowStatus[]
  tasks     Task[]
  tags      Tag[]

  @@index([clientId])
}

model ProjectMember {
  id        String      @id @default(cuid())
  projectId String
  userId    String
  role      ProjectRole @default(VIEWER)
  createdAt DateTime    @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([userId])
}

model ProjectProduct {
  projectId String
  productId String

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@id([projectId, productId])
  @@index([productId])
}

// Phase 4: per-project workflow statuses (configurable in Phase 5) + tasks.

model WorkflowStatus {
  id        String  @id @default(cuid())
  projectId String
  name      String
  color     String  @default("#c4c4c4")
  position  Int

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   Task[]

  @@index([projectId])
}

model Task {
  id          String       @id @default(cuid())
  projectId   String
  title       String
  description String?
  statusId    String
  priority    TaskPriority @default(MEDIUM)
  assigneeId  String?
  ownerId     String
  dueDate     DateTime?
  position    Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  project  Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  status   WorkflowStatus @relation(fields: [statusId], references: [id], onDelete: Restrict)
  assignee User?          @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  owner    User           @relation("TaskOwner", fields: [ownerId], references: [id])
  tags     TaskTag[]
  comments Comment[]
  activities TaskActivity[]

  @@index([projectId])
  @@index([statusId])
  @@index([assigneeId])
}

model TaskActivity {
  id        String       @id @default(cuid())
  taskId    String
  userId    String
  type      ActivityType
  field     String?
  oldValue  String?
  newValue  String?
  createdAt DateTime     @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@index([taskId])
}

model Comment {
  id        String   @id @default(cuid())
  taskId    String
  authorId  String
  bodyHtml  String
  createdAt DateTime @default(now())

  task   Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id])

  @@index([taskId])
}

model Tag {
  id        String    @id @default(cuid())
  projectId String
  name      String
  color     String    @default("#0073ea")
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks     TaskTag[]

  @@unique([projectId, name])
  @@index([projectId])
}

model TaskTag {
  taskId String
  tagId  String

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([taskId, tagId])
  @@index([tagId])
}
